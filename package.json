{
  "name": "edge-drop",
  "version": "0.1.0",
  "description": "Edge-Drop — a clipboard manager that lives on the left edge of your screen and expands on hover.",
  "author": "Edge-Drop",
  "license": "MIT",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.0",
    "electron-vite": "^2.1.0",
    "typescript": "^5.4.3",
    "vite": "^5.2.6"
  },
  "dependencies": {
    "framer-motion": "^11.0.24",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  }
}
